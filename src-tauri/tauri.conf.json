{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lamp Bench",
  "version": "0.1.0",
  "identifier": "com.lampbench.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lamp Bench",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../resources/apache/": "./resources/apache/",
      "../resources/composer/": "./resources/composer/",
      "../resources/mysql-8.0/": "./resources/mysql-8.0/",
      "../resources/php-8.4/": "./resources/php-8.4/",
      "../resources/phpmyadmin/": "./resources/phpmyadmin/"
    }
  }
}
